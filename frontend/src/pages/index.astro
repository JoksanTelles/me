---
import Layout from "../layouts/Layout.astro";
import CtaForm from "../components/CtaForm/CtaForm.astro";
import Title from "../components/ui/typography/Title/Title.astro";
import Hero from "../sections/Hero/Hero.astro";
import Badge from "../components/ui/elements/Badge/Badge.astro";
import Button from "../components/ui/elements/Button/Button.astro";
import Text from "../components/ui/typography/Text/Text.astro";

const siteName = import.meta.env.PUBLIC_SITE_NAME || "Joksan Telles";
---

<Layout title={`${siteName} — Design & Development`}>
    <!-- HERO -->
    <Hero>
        <Fragment slot="content">
            <div class="space-y-4">
                <Badge> Product Designer & Developer </Badge>
                <Title>
                    Joksan <span class="highlight">Télles</span>
                </Title>
            </div>
            <Text
                size="2xl"
                light
                class="max-w-3xl leading-[1.1] text-slate-400"
            >
                Diseño sistemas que hacen <span
                    class="text-slate-900 font-normal">obvio lo complejo.</span
                >
                <span class="text-brand-yellow font-normal">.</span>
            </Text>
        </Fragment>
        <Fragment slot="buttons">
            <Button href="#contacto" variant="primary"> Contáctame </Button>
            <Button href="#principios" variant="secondary">
                Explorar trabajo →
            </Button>
        </Fragment>
    </Hero>

    <!-- BELIEFS -->
    <section id="principios" class="py-48 px-6 bg-slate-50">
        <div class="max-w-7xl mx-auto">
            <h2
                class="text-5xl md:text-7xl mb-32 font-light tracking-tight text-slate-900"
            >
                Principios <span class="highlight italic">fundamentales</span>
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-24 md:gap-32">
                {
                    [
                        {
                            title: "Claridad",
                            descriptor: "Eliminar fricción.",
                            desc: "Cada decisión visual o funcional debe servir al usuario para lograr su objetivo con el mínimo esfuerzo.",
                        },
                        {
                            title: "Automatización",
                            descriptor: "Sistemas eficientes.",
                            desc: "Un sistema interno bien diseñado da control real de procesos, datos y resultados.",
                        },
                        {
                            title: "Seguridad",
                            descriptor: "Respeto al usuario.",
                            desc: "La confianza se gana con transparencia y protección absoluta de la información.",
                        },
                    ].map((belief, i) => (
                        <div class="space-y-8">
                            <p class="text-[10px] uppercase tracking-[0.4em] text-slate-300 font-bold">
                                0{i + 1} // {belief.descriptor}
                            </p>
                            <h3 class="text-4xl font-medium text-slate-900 underline decoration-slate-200 underline-offset-8">
                                {belief.title}
                            </h3>
                            <Text size="xl" light class="leading-relaxed">
                                {belief.desc}
                            </Text>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- SOLUTIONS -->
    <section class="py-48 px-6 bg-slate-100/50">
        <div class="max-w-7xl mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-32">
                <div class="space-y-12">
                    <h2
                        class="text-6xl md:text-8xl font-light tracking-tighter leading-none"
                    >
                        Soluciones <br />
                        <span class="italic font-normal">Digitales</span>
                    </h2>
                    <Text
                        size="2xl"
                        light
                        class="max-w-md italic border-l-4 border-slate-200 pl-8"
                    >
                        Optimizando la intersección entre diseño, datos y
                        procesos operativos.
                    </Text>
                </div>

                <div class="space-y-32">
                    <div class="space-y-12">
                        <h3 class="text-4xl font-medium text-slate-900">
                            Integración & Sincronización
                        </h3>
                        <ul class="space-y-8">
                            {
                                [
                                    "CRM, ERP & E-commerce",
                                    "Ecosistemas de APIs",
                                    "Datos en tiempo real",
                                ].map((item) => (
                                    <li class="text-2xl text-slate-400 font-light flex items-center gap-6 group hover:text-slate-900 transition-colors">
                                        <span class="w-12 h-px bg-slate-300 group-hover:bg-brand-rose transition-colors" />
                                        {item}
                                    </li>
                                ))
                            }
                        </ul>
                    </div>

                    <div class="space-y-12">
                        <h3 class="text-4xl font-medium text-slate-900">
                            Automatización Operativa
                        </h3>
                        <ul class="space-y-8">
                            {
                                [
                                    "Gestión inteligente de leads",
                                    "Workflows asíncronos",
                                    "Fidelización automática",
                                ].map((item) => (
                                    <li class="text-2xl text-slate-400 font-light flex items-center gap-6 group hover:text-slate-900 transition-colors">
                                        <span class="w-12 h-px bg-slate-300 group-hover:bg-brand-rose transition-colors" />
                                        {item}
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- STACK / TOOLS -->
    <section class="py-48 px-6 bg-[#020617] text-white">
        <div
            class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start gap-16"
        >
            <h2
                class="text-xl uppercase tracking-[0.5em] text-slate-700 font-bold min-w-[200px]"
            >
                TOOLKIT
            </h2>
            <div class="flex flex-wrap gap-x-12 gap-y-12">
                {
                    [
                        "Figma",
                        "HTML5",
                        "Astro",
                        "Python",
                        "FastAPI",
                        "n8n",
                        "Docker",
                        "Vue",
                    ].map((tool) => (
                        <div class="group cursor-default">
                            <span class="text-2xl md:text-4xl font-light text-slate-600 group-hover:text-brand-rose transition-all duration-500 italic block">
                                {tool}
                            </span>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- CONTACT FORM SECTION -->
    <section id="contacto" class="py-48 px-6 bg-slate-50">
        <div class="max-w-4xl mx-auto space-y-24">
            <div class="text-center space-y-8">
                <h2
                    class="text-7xl md:text-9xl font-semibold tracking-tighter leading-none"
                >
                    Hablemos <span class="highlight">.</span>
                </h2>
                <Text size="2xl" light class="opacity-60">
                    Propuestas, colaboraciones o consultas técnicas.
                </Text>
            </div>

            <div class="pt-12">
                <div class="bg-white p-12 shadow-sm border border-slate-100">
                    <CtaForm />
                </div>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer
        class="py-24 px-6 border-t border-slate-50 text-slate-400 text-xs tracking-widest uppercase"
    >
        <div
            class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-12"
        >
            <div class="font-bold">
                © {new Date().getFullYear()}
                {siteName}
            </div>
            <div class="flex gap-12 font-medium">
                <a href="#" class="hover:text-brand-rose transition-colors"
                    >LinkedIn</a
                >
                <a href="#" class="hover:text-brand-rose transition-colors"
                    >GitHub</a
                >
                <a href="#" class="hover:text-brand-rose transition-colors"
                    >Dribbble</a
                >
            </div>
        </div>
    </footer>
</Layout>

<style is:global>
    @reference "../styles/global.css";

    /* Absolute legibility and clean spacing */
    .highlight {
        color: var(--color-brand-rose);
    }

    section {
        outline: 2px solid transparent;
        outline-offset: 2px;
        transition-property: none;
    }

    ::selection {
        background-color: var(--color-rose-50);
        color: var(--color-brand-rose);
    }
</style>
