---
import Layout from "../layouts/Layout.astro";
import Icon from "../components/Icon/Icon.astro";
import AnimatedBackground from "../components/AnimatedBackground/AnimatedBackground.astro";
import ThemeToggle from "../components/ThemeToggle/ThemeToggle.astro";
import CtaForm from "../components/CtaForm/CtaForm.astro";
import Title from "../components/ui/typography/Title/Title.astro";
import Hero from "../sections/Hero/Hero.astro";
import Badge from "../components/ui/elements/Badge/Badge.astro";
import Text from "../components/ui/typography/Text/Text.astro";

const siteName = import.meta.env.PUBLIC_SITE_NAME || "Joksan Telles";
---

<Layout title={`${siteName} — Product Designer and Developer`}>
    <AnimatedBackground />
    <ThemeToggle />

    <!-- SECTION 1: HERO -->
    <Hero>
        <Fragment slot="content">
            <Title>
                <span class="text-rose-500">Joksan Télles</span> — Product Designer
                and Developer
            </Title>
            <Badge> Diseño sistemas que hacen obvio lo complejo :) </Badge>
            <Text size="2xl">
                Soy una persona creativa, de mente curiosa y multifacética. Me
                apasiona descubrir la solución a los problemas.
            </Text>
        </Fragment>
        <Fragment slot="buttons">
            <a
                href="#contacto"
                class="group relative inline-flex items-center justify-center px-10 py-6 font-anton text-2xl md:text-5xl bg-rose-500 text-white border-4 border-stone-900 dark:border-stone-100 hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-none shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] dark:shadow-[12px_12px_0px_0px_rgba(255,255,255,1)] transition-all uppercase"
            >
                Contáctame
            </a>
            <a
                href="#lo-que-hago"
                class="group relative inline-flex items-center justify-center px-10 py-6 font-anton text-2xl md:text-5xl bg-stone-50 dark:bg-stone-900 text-stone-900 dark:text-stone-100 border-4 border-stone-900 dark:border-stone-100 hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-none shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] dark:shadow-[12px_12px_0px_0px_rgba(255,255,255,1)] transition-all uppercase"
            >
                Lo qué hago
            </a>
        </Fragment>
    </Hero>

    <!-- SECTION 2: BELIEFS -->
    <section
        id="lo-que-hago"
        class="py-32 px-6 bg-stone-100 dark:bg-stone-900/50 border-y-4 border-stone-900 dark:border-stone-100"
    >
        <div class="max-w-7xl mx-auto">
            <h2 class="text-5xl md:text-8xl mb-24 leading-none">
                Mis principios <br /> de diseño
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                {
                    [
                        {
                            title: "Claridad",
                            descriptor:
                                "El diseño que elimina fricción y maximiza el valor.",
                            desc: "Cada decisión visual o funcional debe servir al usuario para lograr su objetivo con el mínimo esfuerzo. El buen diseño reduce el esfuerzo cognitivo y amplifica la claridad.",
                            icon: "visibility",
                        },
                        {
                            title: "Automatización",
                            descriptor:
                                "La automatización como asistente, no reemplazo.",
                            desc: "Un sistema interno bien diseñado da control real de procesos, datos y resultados. Diseñar control es permitir decisiones seguras y contextos previsibles.",
                            icon: "auto_mode",
                        },
                        {
                            title: "Seguridad",
                            descriptor:
                                "Diseñar con seguridad es diseñar con respeto.",
                            desc: "La confianza del usuario es un activo que se gana con transparencia, control y protección real de sus datos. La seguridad empieza en el diseño, no en la ingeniería.",
                            icon: "security",
                        },
                    ].map((belief) => (
                        <div class="group p-8 bg-stone-50 dark:bg-stone-950 border-4 border-stone-900 dark:border-stone-100 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:shadow-[8px_8px_0px_0px_rgba(255,255,255,1)] hover:translate-y-[-8px] transition-transform">
                            <div class="w-16 h-16 bg-yellow-400 border-2 border-stone-900 flex items-center justify-center mb-8">
                                <Icon
                                    name={belief.icon}
                                    class="text-4xl text-stone-900"
                                />
                            </div>
                            <h3 class="text-4xl mb-4 text-rose-500">
                                {belief.title}
                            </h3>
                            <p class="text-lg font-bold italic mb-6 text-stone-500 underline decoration-yellow-400 decoration-4 underline-offset-4">
                                {belief.descriptor}
                            </p>
                            <p class="text-stone-600 dark:text-stone-400 leading-relaxed">
                                {belief.desc}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- SECTION 3: SERVICES -->
    <section class="py-32 px-6 max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-24">
            <div>
                <h2 class="text-6xl md:text-8xl mb-8 leading-[0.9]">
                    Soluciones <br /> Digitales
                </h2>
                <p
                    class="text-2xl text-stone-500 leading-relaxed font-medium underline decoration-stone-300 dark:decoration-stone-700 decoration-1 underline-offset-12"
                >
                    Mi trabajo se centra en optimizar procesos, integrar
                    plataformas y crear herramientas web que potencien la
                    eficiencia operativa.
                </p>
            </div>

            <div class="space-y-16">
                <div class="space-y-6">
                    <div class="flex items-start gap-4">
                        <span class="text-4xl font-anton text-rose-500">I.</span
                        >
                        <h3 class="text-3xl md:text-4xl">
                            Integración y Sincronización de Datos
                        </h3>
                    </div>
                    <p class="text-lg text-stone-600 dark:text-stone-300">
                        Diseño flujos que conectan plataformas y bases de datos
                        para mantener la información actualizada en todo
                        momento.
                    </p>
                    <ul class="space-y-3">
                        {
                            [
                                "Integraciones entre CRM, ERP y e-commerce.",
                                "Conexiones entre APIs, hojas de cálculo y sistemas locales.",
                                "Consolidación de datos dispersos para análisis en tiempo real.",
                            ].map((item) => (
                                <li class="flex items-center gap-2 font-bold">
                                    <Icon
                                        name="chevron_right"
                                        class="text-yellow-500"
                                    />
                                    {item}
                                </li>
                            ))
                        }
                    </ul>
                </div>

                <div class="space-y-6">
                    <div class="flex items-start gap-4">
                        <span class="text-4xl font-anton text-rose-500"
                            >II.</span
                        >
                        <h3 class="text-3xl md:text-4xl">
                            Automatización del Ciclo de Vida del Cliente
                        </h3>
                    </div>
                    <p class="text-lg text-stone-600 dark:text-stone-300">
                        Automatizo la gestión completa del cliente, desde el
                        momento en que deja sus datos hasta el seguimiento
                        post-venta.
                    </p>
                    <ul class="space-y-3">
                        {
                            [
                                "Captura y validación automática de leads.",
                                "Lanzamiento de campañas personalizadas por correo o redes.",
                                "Automatización de recordatorios, encuestas y fidelización.",
                            ].map((item) => (
                                <li class="flex items-center gap-2 font-bold">
                                    <Icon
                                        name="chevron_right"
                                        class="text-yellow-500"
                                    />
                                    {item}
                                </li>
                            ))
                        }
                    </ul>
                </div>

                <div class="space-y-6">
                    <div class="flex items-start gap-4">
                        <span class="text-4xl font-anton text-rose-500"
                            >III.</span
                        >
                        <h3 class="text-3xl md:text-4xl">
                            Desarrollo de software a medida
                        </h3>
                    </div>
                    <p class="text-lg text-stone-600 dark:text-stone-300">
                        Desarrollo aplicaciones web adaptadas a las necesidades
                        de cada cliente que sean ligeras, seguras y escalables.
                    </p>
                    <ul class="space-y-3">
                        {
                            [
                                "Aplicaciones de gestión interna empresarial.",
                                "Paneles administrativos y sistemas de monitoreo.",
                                "Dashboards interactivos y visualización de datos.",
                            ].map((item) => (
                                <li class="flex items-center gap-2 font-bold">
                                    <Icon
                                        name="chevron_right"
                                        class="text-yellow-500"
                                    />
                                    {item}
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 4: STACK -->
    <section
        class="py-32 px-6 bg-stone-900 text-stone-100 border-y-10 border-yellow-400"
    >
        <div class="max-w-7xl mx-auto text-center">
            <h2 class="text-5xl md:text-8xl italic mb-8">
                Mi ecosistema de herramientas
            </h2>
            <p
                class="text-xl md:text-2xl text-stone-400 max-w-3xl mx-auto mb-20 leading-relaxed"
            >
                Este es mi stack base que mantiene un equilibrio entre
                rendimiento, escalabilidad y facilidad de mantenimiento.
            </p>

            <div class="flex flex-wrap justify-center gap-4 md:gap-8">
                {
                    [
                        "Figma",
                        "HTML5",
                        "CSS3",
                        "JavaScript",
                        "Python",
                        "Node.js",
                        "Astro",
                        "FastAPI",
                        "SQLite",
                        "PostgreSQL",
                        "Scrum",
                        "n8n",
                        "GitHub",
                        "Docker",
                        "DigitalOcean",
                        "Netlify",
                        "Vue",
                        "Postman",
                        "Notion",
                        "VSCode",
                        "EOS",
                    ].map((tool) => (
                        <span class="text-3xl md:text-5xl font-anton opacity-40 hover:opacity-100 hover:text-rose-500 transition-all cursor-default uppercase">
                            {tool}
                        </span>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- SECTION 6: CTA -->
    <section id="contacto" class="py-48 px-6 bg-yellow-400 text-stone-900">
        <div class="max-w-7xl mx-auto mb-24 text-center">
            <h2 class="text-6xl md:text-[8rem] leading-[0.8] mb-8">
                ¿Necesitas convertir <br /> una idea en realidad?
            </h2>
            <p
                class="text-2xl md:text-4xl font-bold max-w-4xl mx-auto leading-tight italic"
            >
                Agenda una reunión para ayudarte a transformar tu idea en un
                producto funcional y escalable.
            </p>
        </div>

        <CtaForm />
    </section>

    <footer
        class="py-12 px-6 bg-stone-950 text-stone-500 font-bold border-t-2 border-stone-800"
    >
        <div
            class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8"
        >
            <div class="text-xl">
                © {new Date().getFullYear()}
                {siteName} / EOS Ecosystem.
            </div>
            <div class="flex gap-8 text-stone-100">
                <a href="#" class="hover:text-rose-500 transition-colors"
                    >LINKEDIN</a
                >
                <a href="#" class="hover:text-rose-500 transition-colors"
                    >GITHUB</a
                >
                <a href="#" class="hover:text-rose-500 transition-colors"
                    >X / TWITTER</a
                >
            </div>
        </div>
    </footer>
</Layout>

<style>
    h1,
    h2,
    h3 {
        font-family: "Anton", sans-serif;
    }

    .animate-in {
        animation: slide-up 1s ease-out forwards;
    }

    @keyframes slide-up {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
