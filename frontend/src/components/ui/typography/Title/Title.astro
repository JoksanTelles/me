---
interface Props {
    level?: 1 | 2 | 3 | 4;
    class?: string;
    id?: string;
}

const { level = 1, class: className = "", id } = Astro.props;
const Tag = `h${level}` as any;

const styles = {
    1: "text-7xl md:text-9xl lg:text-[12rem] font-semibold leading-[0.85] tracking-tighter",
    2: "text-5xl md:text-8xl font-medium tracking-tight",
    3: "text-4xl md:text-6xl font-medium tracking-tight",
    4: "text-2xl md:text-4xl font-medium tracking-tight",
};

const baseStyles = "transition-all duration-300 text-slate-950 font-heading";
---

<Tag
    {id}
    class:list={[baseStyles, styles[level as keyof typeof styles], className]}
>
    <slot />
</Tag>
