---
import "./Title.css";

interface Props {
    level?: 1 | 2 | 3 | 4;
    class?: string;
}

const { level = 1, class: className = "" } = Astro.props;
const Tag = `h${level}` as any;

const styles = {
    1: "text-6xl sm:text-8xl md:text-9xl lg:text-[11rem] leading-[0.85] font-anton uppercase",
    2: "text-5xl md:text-8xl font-anton uppercase leading-none",
    3: "text-4xl md:text-5xl font-anton uppercase",
    4: "text-2xl md:text-3xl font-anton uppercase",
};

const baseStyles = "transition-colors duration-300";
// Theme logic is usually handled by global CSS classes in this project (dark:text-stone-100)
// but we can add utility classes to the props.
---

<Tag class:list={[baseStyles, styles[level as keyof typeof styles], className]}>
    <slot />
</Tag>
