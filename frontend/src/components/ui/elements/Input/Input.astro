---
interface Props {
    label?: string;
    type?: "text" | "email" | "tel" | "url" | "password";
    name?: string;
    id?: string;
    placeholder?: string;
    required?: boolean;
    class?: string;
}

const {
    label,
    type = "text",
    name,
    id,
    placeholder,
    required = false,
    class: className = "",
} = Astro.props;
---

<div class:list={["space-y-2 w-full", className]}>
    {
        label && (
            <label
                for={id}
                class="block font-bold text-stone-900 dark:text-stone-100 uppercase tracking-wider"
            >
                {label}
            </label>
        )
    }
    <input
        type={type}
        name={name}
        id={id}
        placeholder={placeholder}
        required={required}
        class="w-full p-4 bg-transparent border-2 border-stone-900 dark:border-stone-100 text-stone-900 dark:text-stone-100 outline-none transition-colors focus:bg-yellow-400 focus:text-stone-900 placeholder:text-stone-400 dark:placeholder:text-stone-600"
    />
</div>
