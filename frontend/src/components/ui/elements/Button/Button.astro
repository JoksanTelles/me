---
interface Props {
    variant?: "primary" | "secondary";
    href?: string;
    class?: string;
    id?: string;
}

const { variant = "primary", href, class: className = "", id } = Astro.props;

const Element = href ? "a" : "button";

const baseStyles =
    "relative inline-flex items-center justify-center px-8 py-4 font-body font-medium text-lg md:text-xl transition-all duration-300 cursor-pointer active:scale-95 rounded-sm overflow-hidden";

const variants = {
    primary: "bg-slate-900 text-white hover:bg-brand-rose",
    secondary:
        "bg-white text-slate-900 border border-slate-200 hover:border-slate-900",
};

const sizes = "";
---

<Element
    {href}
    {id}
    class:list={[baseStyles, variants[variant], sizes, className]}
>
    <slot />
</Element>
