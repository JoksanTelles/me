---
interface Props {
    variant?: "primary" | "secondary";
    href?: string;
    class?: string;
    type?: "button" | "submit" | "reset";
    id?: string;
}

const {
    variant = "primary",
    href,
    class: className = "",
    type = "button",
    id,
} = Astro.props;

const Element = href ? "a" : "button";

const baseStyles =
    "relative inline-flex items-center justify-center font-anton uppercase transition-all cursor-pointer border-4 border-stone-900 dark:border-stone-100 hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-none active:scale-95";

const variants = {
    primary:
        "bg-rose-500 text-white shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:shadow-[8px_8px_0px_0px_rgba(255,255,255,1)]",
    secondary:
        "bg-stone-50 dark:bg-stone-900 text-stone-900 dark:text-stone-100 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:shadow-[8px_8px_0px_0px_rgba(255,255,255,1)]",
};

const sizes = "px-10 py-6 text-2xl md:text-5xl";
---

<Element
    id={id}
    href={href}
    type={href ? undefined : type}
    class:list={[baseStyles, variants[variant], sizes, className]}
>
    <slot />
</Element>
